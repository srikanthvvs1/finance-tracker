# FinTrack Google Sheets Configuration
# Copy this file to config/gsheets.env and fill in your values.

# Service account credentials JSON file (relative to config/ folder)
GSHEETS_CREDS_FILE=your-credentials-file.json

# Google Spreadsheet ID (from the sheet URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit)
GSHEETS_SPREADSHEET_ID=your-spreadsheet-id-here

# OAuth2 client secret JSON for Drive (Desktop app type, from Google Cloud Console)
# Download from: APIs & Services > Credentials > OAuth 2.0 Client IDs
DRIVE_OAUTH_CLIENT_FILE=client_secret.json

# Google Drive folder name for documents (default: Finance)
# DRIVE_PARENT_FOLDER=Finance
